#!/bin/bash
set -euo pipefail

NWALKERS="${NWALKERS:-16}"
OUTDIR="${OUTDIR:-all_traj}"
GMX="${GMX:-gmx_mpi}"

mkdir -p "$OUTDIR"

# 找到最大 run 编号
max_run=0
for d in run*; do
  [ -d "$d" ] || continue
  n="${d#run}"
  [[ "$n" =~ ^[0-9]+$ ]] || continue
  if (( n > max_run )); then
    max_run=$n
  fi
done

if (( max_run == 0 )); then
  echo "[ERROR] No run* directories found."
  exit 1
fi

echo "[INFO] Found runs: 1 ... $max_run"
echo "[INFO] Output dir: $OUTDIR"

for w in $(seq -f "w%02g" 1 "$NWALKERS"); do
  files=()

  for ((r=1; r<=max_run; r++)); do
    f="run${r}/${w}/md_center.xtc"
    if [ -f "$f" ]; then
      files+=("$f")
    fi
  done

  if [ "${#files[@]}" -eq 0 ]; then
    echo "[WARN] $w: no md_center.xtc found, skip."
    continue
  fi

  if [ "${#files[@]}" -eq 1 ]; then
    echo "[INFO] $w: only one trajectory, copying."
    cp "${files[0]}" "$OUTDIR/${w}_all.xtc"
    continue
  fi

  echo "[INFO] $w: concatenating ${#files[@]} files"

  # 给 trjcat 自动输入 settime 选项：
  # 第一段输入 0
  # 后面都输入 c (continue)
  {
    echo 0
    for ((i=1; i<${#files[@]}; i++)); do
      echo c
    done
  } | "$GMX" trjcat -f "${files[@]}" -settime -o "$OUTDIR/${w}_all.xtc"

done

echo "[INFO] Done."