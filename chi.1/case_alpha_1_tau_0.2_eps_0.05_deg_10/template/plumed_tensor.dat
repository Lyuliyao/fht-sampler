# vim:ft=plumed
# since simulation run in subdir, we refer to a file in the parent dir:
LOAD FILE=./MetaTensor.so
ome1: TORSION ATOMS=6,1,7,8
phi1: TORSION ATOMS=1,7,8,11
psi1: TORSION ATOMS=7,8,11,30
METATENSOR label=metad ARG=ome1,phi1,psi1 NUMCOLLECTIONS=1 COLLECTIONDIRS=${1} EPS=0.05 TAU_FACTOR=0.2 ALPHA=1
PRINT ARG=ome1,phi1,psi1,metad.bias FILE=COLVAR STRIDE=50 
